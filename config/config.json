{
  "app": {
    "name": "Smart-Catch",
    "version": "0.1",
    "mode": "local"
  },
  "sources": {
    "rss": [
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "min_score": 2,
        "max_age_days": 14
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "min_score": 2,
        "exclude_url_prefixes": [
          "https://openai.com/academy/"
        ],
        "max_age_days": 14
      },
      {
        "name": "Zenn",
        "url": "https://zenn.dev/feed",
        "min_score": 2,
        "max_age_days": 14
      },
      {
        "name": "Qiita",
        "url": "https://qiita.com/popular-items/feed",
        "min_score": 3,
        "max_age_days": 14
      },
      {
        "name": "Google DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "min_score": 2,
        "max_age_days": 14
      },
      {
        "name": "Meta AI Research",
        "url": "https://engineering.fb.com/category/ai-research/feed/",
        "min_score": 2,
        "max_age_days": 7
      },
      {
        "name": "ITmedia AI",
        "url": "https://rss.itmedia.co.jp/rss/2.0/aiplus.xml",
        "min_score": 2,
        "max_age_days": 14
      }
    ],
    "web": [],
    "api": []
  },
  "monitoring": {
    "enabled": true,
    "min_score": 2,
    "keywords": [
      "AI",
      "人工知能",
      "生成AI",
      "ChatGPT",
      "OpenAI",
      "Claude",
      "Claude Code",
      "Codex",
      "LLM",
      "大規模言語モデル",
      "agent",
      "agents",
      "transformers",
      "model",
      "models",
      "open source",
      "local AI",
      "機械学習",
      "ディープラーニング",
      "推論",
      "自動化",
      "Cursor",
      "Copilot",
      "Windsurf",
      "Devin",
      "Bolt",
      "Dify",
      "LangChain",
      "LlamaIndex",
      "Ollama",
      "Perplexity",
      "Gemini",
      "Grok",
      "OpenCLAW",
      "RAG",
      "fine-tuning",
      "プロンプトエンジニアリング",
      "MCP",
      "エージェント",
      "マルチモーダル",
      "embedding",
      "Altman",
      "Dario",
      "LeCun",
      "Hinton"
    ],
    "keyword_weights": {
      "ChatGPT": 3,
      "OpenAI": 3,
      "Claude": 3,
      "Claude Code": 4,
      "Codex": 4,
      "LLM": 2,
      "生成AI": 2
    },
    "match_mode": "partial"
  },
  "deduplication": {
    "enabled": true,
    "mode": "url_and_title"
  },
  "summary_generation": {
    "enabled": true
  },
  "exploration": {
    "enabled": true,
    "max_items": 20
  },
  "output": {
    "base_dir": "output",
    "monitoring_dir": "output/monitoring",
    "exploration_dir": "output/exploration",
    "format": "markdown",
    "save_history": true
  },
  "logging": {
    "level": "INFO",
    "save_to_file": true,
    "log_dir": "logs"
  },
  "network": {
    "timeout_seconds": 10
  },
 "ollama": {
  "host": "http://192.168.0.4:11434/",
  "model": "qwen2.5:14b"
}

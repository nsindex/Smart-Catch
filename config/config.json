{
  "app": {
    "name": "Smart-Catch",
    "version": "0.1",
    "mode": "local"
  },

  "sources": {
    "rss": [
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "max_items": 10
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "max_items": 10
      },
      {
        "name": "Zenn",
        "url": "https://zenn.dev/feed",
        "max_items": 10
      },
      {
        "name": "Qiita",
        "url": "https://qiita.com/popular-items/feed",
        "max_items": 10,
        "min_score": 3
      }
    ],
    "web": [],
    "api": []
  },

  "monitoring": {
    "enabled": true,
    "keywords": [
      "AI",
      "人工知能",
      "生成AI",
      "ChatGPT",
      "OpenAI",
      "Claude",
      "Claude Code",
      "Codex",
      "LLM",
      "大規模言語モデル",
      "agent",
      "agents",
      "transformers",
      "model",
      "models",
      "open source",
      "local AI",
      "機械学習",
      "ディープラーニング",
      "推論",
      "自動化"
    ],
    "keyword_weights": {
      "ChatGPT": 3,
      "OpenAI": 3,
      "Claude": 3,
      "Claude Code": 4,
      "Codex": 4,
      "LLM": 2,
      "生成AI": 2
    },
    "match_mode": "partial"
  },

  "deduplication": {
    "enabled": false,
    "mode": "url_and_title"
  },

  "summary_generation": {
    "enabled": true
  },

  "exploration": {
    "enabled": true,
    "max_items": 20
  },

  "output": {
    "base_dir": "output",
    "monitoring_dir": "output/monitoring",
    "exploration_dir": "output/exploration",
    "format": "markdown",
    "save_history": true
  },

  "logging": {
    "level": "INFO",
    "save_to_file": true,
    "log_dir": "logs"
  },

  "network": {
    "timeout_seconds": 10
  }
}
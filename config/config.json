{
  "app": {
    "name": "Smart-Catch",
    "version": "0.1",
    "mode": "local"
  },

  "sources": {
    "rss": [
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "max_items": 20
      }
    ],
    "web": [],
    "api": []
  },

  "monitoring": {
    "enabled": true,
   "keywords": [
  "AI",
  "人工知能",
  "生成AI",
  "ChatGPT",
  "OpenAI",
  "Claude",
  "Claude Code",
  "Codex",
  "LLM",
  "大規模言語モデル",
  "agent",
  "agents",
  "transformers",
  "model",
  "models",
  "open source",
  "local AI",
  "機械学習",
  "ディープラーニング",
  "推論",
  "自動化"
],
    "match_mode": "partial"
  },

  "exploration": {
    "enabled": true,
    "max_items": 20
  },

  "output": {
    "base_dir": "output",
    "monitoring_dir": "output/monitoring",
    "exploration_dir": "output/exploration",
    "format": "markdown"
  },

  "logging": {
    "level": "INFO",
    "save_to_file": true,
    "log_dir": "logs"
  },

  "network": {
    "timeout_seconds": 10
  }
}